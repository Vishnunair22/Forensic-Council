# Auto-normalize line endings
* text=auto

# Source code — LF endings
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.editorconfig text eol=lf
*.css text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.mp4 binary
*.mp3 binary
*.wav binary
*.pyc binary
*.so binary
*.o binary

# Lock files
package-lock.json binary
uv.lock binary
