# ============================================================================
# Backend .dockerignore — Keep build context lean
# ============================================================================

# Python bytecode
__pycache__/
*.py[cod]
*.so
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Env files and secrets
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
.credentials
.aws
.ssh

# Storage and model caches (mounted via Docker volumes at runtime)
storage/evidence/
storage/keys/

# Calibration models MUST be baked into the image for first-run seeding
!storage/calibration_models/
!storage/calibration_models/**/*

cache/
.cache/
.vector_cache/
.ipynb_checkpoints/

# Version control
.git/
.gitignore
.github/
*.md
README*

# OS artifacts
.DS_Store
Thumbs.db
**/.DS_Store
**/Thumbs.db

# IDE
.vscode/
.idea/

# Logs & temporary
*.log
logs/
tmp/
temp/

# Build artifacts
dist/
build/
*.egg-info/
*.whl
