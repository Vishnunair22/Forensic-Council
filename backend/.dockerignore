# ============================================================================
# Backend .dockerignore — Keep build context lean
# ============================================================================

# Python bytecode
__pycache__/
*.py[cod]
*.so
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Dev / test files
tests/
*.test.*
.env
.env.*
!.env.example

# Storage and model caches (mounted via Docker volumes at runtime)
storage/evidence/
storage/keys/
cache/

# Version control
.git/
.gitignore
*.md
README*

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
logs/

# Build artifacts
dist/
build/
*.egg-info/
*.whl
