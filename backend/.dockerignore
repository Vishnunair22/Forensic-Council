# ============================================================================
# Backend .dockerignore
# ============================================================================
# Prevents unnecessary files from being sent as Docker build context.
# This dramatically speeds up builds and prevents secrets from leaking.

# Python bytecode and caches
__pycache__/
*.py[cod]
*.so
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Virtual environments (Docker installs its own via uv)
.venv/
venv/
env/

# Development / test files
tests/
*.test.*
.env
.env.*
!.env.example

# Storage and model caches (injected via Docker volumes at runtime)
storage/evidence/
storage/keys/
cache/

# Version control
.git/
.gitignore

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Documentation
*.md
docs/

# Logs
*.log
logs/

# Build artifacts
dist/
build/
*.egg-info/
*.whl
