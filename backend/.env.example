# ============================================================================
# Forensic Council — Backend Environment Variables
# ============================================================================
# This file is used when running the backend NATIVELY (outside Docker).
# Copy to backend/.env:
#   cp backend/.env.example backend/.env
#
# When running in Docker, environment variables are injected by docker-compose
# and this file is NOT used.
# ============================================================================

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# Security
SIGNING_KEY=dev-placeholder-change-me-in-production-generate-with-secrets-token-hex-32

# Redis (when using infra via docker-compose.infra.yml)
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=forensic_pass
POSTGRES_DB=forensic_council

# LLM Provider (Groq recommended — free at https://console.groq.com/keys)
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile

# HuggingFace (required for Agent 2 speaker diarization)
HF_TOKEN=

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Bootstrap credentials
BOOTSTRAP_INVESTIGATOR_PASSWORD=inv123!
BOOTSTRAP_ADMIN_PASSWORD=admin123!

# Storage paths
EVIDENCE_STORAGE_PATH=./storage/evidence
CALIBRATION_MODELS_PATH=./cache/calibration_models
