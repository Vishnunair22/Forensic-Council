# ===========================================
# Forensic Council Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -------------------
# Application Settings
# -------------------
APP_NAME=forensic_council
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -------------------
# Redis Configuration
# -------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# -------------------
# Qdrant Configuration
# -------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# -------------------
# PostgreSQL Configuration
# -------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=forensic_pass
POSTGRES_DB=forensic_council

# Database URL (constructed from above or override)
DATABASE_URL=postgresql://forensic_user:forensic_pass@localhost:5432/forensic_council

# -------------------
# Storage Configuration
# -------------------
EVIDENCE_STORAGE_PATH=./storage/evidence
CALIBRATION_MODELS_PATH=./storage/calibration_models

# -------------------
# Security Configuration
# -------------------
# Key for signing audit trail entries (Required: generate a strong 32-byte hex key)
# Run: python -c "import secrets; print(secrets.token_hex(32))"
# For development, this placeholder works but will fail in production.
SIGNING_KEY=dev-signing-key-replace-in-production

# JWT Configuration (Optional - defaults to SIGNING_KEY if not set)
# Set this to a consistent value to prevent token invalidation on rebuilds
# If not set, JWT tokens will be signed with SIGNING_KEY
# Run: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET_KEY=

# JWT Token Expiration (in minutes)
# Default: 10080 minutes (7 days)
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS allowed origins (JSON array format)
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# -------------------
# Agent Configuration
# -------------------
DEFAULT_ITERATION_CEILING=20
HITL_ENABLED=true

# Maximum seconds for a single investigation before timeout
INVESTIGATION_TIMEOUT=300

# -------------------
# ML Model API Tokens
# -------------------
# Required for pyannote.audio speaker diarization
# Free token at https://hf.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token_here
