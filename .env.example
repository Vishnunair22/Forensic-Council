# =========================================================================
# Forensic Council — Master Environment Configuration
# =========================================================================
# Instructions:
# 1. Copy this file to `.env` in the root directory.
# 2. Copy backend/.env.example to backend/.env
# 3. Update the values for your specific environment.
# 4. DO NOT commit `.env` to version control.
#
# Docker Compose Files:
#   - docker-compose.infra.yml  : Infrastructure only (Redis, Postgres, Qdrant)
#   - docker-compose.yml        : Base service definitions
#   - docker-compose.override.yml : Development overrides (auto-loaded)
#   - docker-compose.prod.yml   : Production overrides
#
# Quick Start:
#   docker compose -f docker-compose.infra.yml up -d  # Start databases
#   cd backend && uv run uvicorn api.main:app --reload  # Native backend
#   cd frontend && npm run dev  # Native frontend
#
# See docs/STARTUP.md for full details.
# =========================================================================

# -------------------------------------------------------------------------
# Core Application Settings
# -------------------------------------------------------------------------
# Valid values: 'development', 'production', 'testing'
APP_ENV=development

# Enable debug mode to see full tracebacks (set to false in production)
DEBUG=true

# Logging verbosity (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# -------------------------------------------------------------------------
# Security & Cryptography
# -------------------------------------------------------------------------
# CRITICAL: This is the ECDSA signing key seed used to cryptographically 
# sign final analysis reports and maintain the chain of custody.
# Must be a secure 32-byte hex string.
# Generate one using: `python -c "import secrets; print(secrets.token_hex(32))"`
SIGNING_KEY=your_secure_hex_key_here

# JWT Configuration (Optional - defaults to SIGNING_KEY if not set)
# Set this to a consistent value to prevent token invalidation on rebuilds
# If not set, JWT tokens will be signed with SIGNING_KEY
# Generate one using: `python -c "import secrets; print(secrets.token_hex(32))"`
# JWT_SECRET_KEY=your_jwt_secret_key_here

# JWT Token Expiration (in minutes)
# Default: 10080 minutes (7 days)
# Set to a lower value for shorter sessions, higher for longer sessions
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Required for the backend to accept frontend requests.
# Set this to exactly match the frontend URL(s). Include protocol and port.
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# -------------------------------------------------------------------------
# Postgres Database (Persistent Custody Logs)
# -------------------------------------------------------------------------
# Credentials for the main Postgres database. 
# Used by both the `postgres` container and the `backend` to connect.
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=forensic_pass
POSTGRES_DB=forensic_council

# -------------------------------------------------------------------------
# Redis (Working Memory & Rate Limiting)
# -------------------------------------------------------------------------
# Only needed if you run the backend *outside* of Docker. 
# Inside Docker, `docker-compose.yml` automatically points the backend to `redis:6379`.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# -------------------------------------------------------------------------
# Qdrant (Vector Storage for Similarity Search)
# -------------------------------------------------------------------------
# Only needed if running outside of Docker.
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# -------------------------------------------------------------------------
# Investigation / Agent Settings
# -------------------------------------------------------------------------
# Max number of total steps an investigation pipeline will attempt before 
# forcing a timeout (prevents infinite loops if an agent gets stuck).
DEFAULT_ITERATION_CEILING=20

# Enable Human-In-The-Loop features. If false, contradictory findings 
# bypass manual review and automatically note uncertainty in the final report.
HITL_ENABLED=true

# Maximum wall-clock time allowed for an investigation before abandoning (seconds).
INVESTIGATION_TIMEOUT=300

# Number of retry attempts for failed investigations
INVESTIGATION_MAX_RETRIES=3

# Base delay between investigation retries (seconds)
INVESTIGATION_RETRY_DELAY=5.0

# Session state TTL in hours (how long to persist session data)
SESSION_TTL_HOURS=24

# Enable PostgreSQL session persistence (recommended for production)
ENABLE_SESSION_PERSISTENCE=true

# -------------------------------------------------------------------------
# Retry Configuration
# -------------------------------------------------------------------------
# Max database connection retries
DATABASE_RETRY_MAX=5

# Base database retry delay (seconds)
DATABASE_RETRY_DELAY=1.0

# Max external API retries
EXTERNAL_API_RETRY_MAX=3

# Base external API retry delay (seconds)
EXTERNAL_API_RETRY_DELAY=1.0

# -------------------------------------------------------------------------
# Storage Paths (Optional Overrides)
# -------------------------------------------------------------------------
# Where uploaded files and analysis artifacts are temporarily stored.
EVIDENCE_STORAGE_PATH=./storage/evidence

# Specific ML calibration models cache location.
CALIBRATION_MODELS_PATH=./storage/calibration_models
