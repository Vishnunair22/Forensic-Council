# ============================================================================
# Forensic Council — Environment Variables (Production-Hardened)
# ============================================================================
# SETUP:
#   1. cp .env.example .env       (bash/zsh)
#      Copy-Item .env.example .env (PowerShell)
#   2. Run ./infra/generate_production_keys.sh to populate secure secrets
#   3. Edit .env with your specific API keys (Groq/Gemini)
#   4. docker compose -f infra/docker-compose.yml --env-file .env up -d
#
# ⚠️  Never commit .env to source control.
# ⚠️  Production mode refuses to start if insecure defaults are detected.
# ============================================================================

# ─── Docker Project Name ─────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=forensic-council

# ─── Application Global Settings ─────────────────────────────────────────────
# Set to 'production' only after running generate_production_keys.sh
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=forensic-council

# ─── Core Security Keys ──────────────────────────────────────────────────────
# CRITICAL: Both keys must be unique, high-entropy, and at least 32 characters.
# Use ./infra/generate_production_keys.sh to generate these safely.

# Primary key for signing forensic audit logs (ECDSA provenance)
SIGNING_KEY=__REPLACE_ME_SIGNING_KEY_MIN_32_CHARS__

# Secret key for JWT authentication session signing
JWT_SECRET_KEY=__REPLACE_ME_JWT_SECRET_MIN_32_CHARS__

# ─── Infrastructure (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=__REPLACE_ME_POSTGRES_PWD_MIN_16_CHARS__
POSTGRES_DB=forensic_council

# Full connection URL for external tools (e.g., DBeaver, pgcli)
# 'postgres' inside Docker, 'localhost' on host
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Infrastructure (Redis) ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# CRITICAL: Production mode REQUIRES a strong Redis password.
# All in-flight forensic state and task data traverses Redis.
REDIS_PASSWORD=__REPLACE_ME_REDIS_PWD_MIN_16_CHARS__

# ─── Infrastructure (Qdrant) ─────────────────────────────────────────────
# Vector database for episodic memory and embedding storage
QDRANT_URL=http://qdrant:6333
# CRITICAL: Production MUST set a strong API key — Qdrant exposes all
# vectors and collections to anyone who can reach port 6333 without one.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
QDRANT_API_KEY=__REPLACE_ME_QDRANT_API_KEY_MIN_32_CHARS__
QDRANT_COLLECTION=forensic_episodic

# ─── Authentication ──────────────────────────────────────────────────────────
# Passwords for the initial 'admin' and 'investigator' users.
# Only used on first run to bootstrap the database.
BOOTSTRAP_ADMIN_PASSWORD=__REPLACE_ME_ADMIN_PWD_MIN_16_CHARS__
BOOTSTRAP_INVESTIGATOR_PASSWORD=__REPLACE_ME_INVESTIGATOR_PWD_MIN_16_CHARS__

# ─── Demo Auth ───────────────────────────────────────────────────────���───────
# Server-side only password for the /api/auth/demo Next.js route.
# NOTE: For local dev "Begin Analysis" button to work (auto-login), 
# this MUST match BOOTSTRAP_INVESTIGATOR_PASSWORD.
# Do NOT rename to NEXT_PUBLIC_DEMO_PASSWORD — that would bake it into the
# client JS bundle. Keep this server-side.
# Change this before any public deployment.
# IMPORTANT: For the demo login and "Begin Analysis" button to work,
# DEMO_PASSWORD must exactly match BOOTSTRAP_INVESTIGATOR_PASSWORD.
DEMO_PASSWORD=${BOOTSTRAP_INVESTIGATOR_PASSWORD}

# ─── Frontend & API Networking ───────────────────────────────────────────────
# Backend API URL reachable from the USER'S BROWSER.
# NOTE: NEXT_PUBLIC_* values are baked into the JS bundle at `next build`.
# Changing this AFTER build does NOT update the running frontend — rebuild the web image.
# Development: http://localhost:8000
# Production:  https://forensic.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal API URL for container-to-container communication (Next.js server-side)
INTERNAL_API_URL=http://backend:8000

# Strict CORS origin control. List all domains allowed to access the API.
# Format: comma-separated list (CSV)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://forensic.yourdomain.com

# ─── LLM Providers ───────────────────────────────────────────────────────────
# Groq (Logic & Reasoning - Llama 3.3 70B)
# Get a key at: https://console.groq.com/keys
LLM_PROVIDER=groq
LLM_API_KEY=__PASTE_GROQ_KEY_HERE__
LLM_MODEL=llama-3.3-70b-versatile
LLM_FALLBACK_MODELS=llama-3.1-8b-instant
LLM_ENABLE_REACT_REASONING=false
LLM_ENABLE_POST_SYNTHESIS=true
USE_REDIS_WORKER=true

# Docker build-time ML cache preload.
# Keep this enabled for solid runtime behavior: backend/worker images download
# YOLO, EasyOCR, OpenCLIP, ResNet-50, SpeechBrain ECAPA, and AASIST during build.
PRELOAD_MODELS=1
YOLO_MODEL_NAME=yolo11n.pt
AASIST_MODEL_NAME=Vansh180/deepfake-audio-wav2vec2

# Google Gemini (Neural Vision & Audio Audit)
# Get a key at: https://aistudio.google.com/apikey
# REQUIRED for Agent 1, 3, 5 deep analysis passes.
GEMINI_API_KEY=__PASTE_GEMINI_KEY_HERE__
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_CONCURRENT=2

# Separate Gemini key for the Council Arbiter (isolates Arbiter quota from agents).
# Leave empty to share the main GEMINI_API_KEY.
ARBITER_GEMINI_API_KEY=

# Gemini timeout in seconds for vision/audio requests (default: 55.0)
GEMINI_TIMEOUT=55.0

# Comma-separated ordered list of fallback Gemini models if the primary is
# unavailable or rate-limited.
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite

# Acknowledge Gemini usage policy (required for API access; set to false to
# block Gemini calls globally, e.g. during testing or air-gapped deployments).
GEMINI_API_KEY_POLICY_OK=true

# ─── Per-provider Free-tier Quota Limits ─────────────────────────────────────
# Used by the quota guard before each call. Set to your actual tier limits.
# Conservative free-tier defaults are pre-filled.
GEMINI_RPM_LIMIT=10
GEMINI_RPD_LIMIT=1500
GROQ_RPM_LIMIT=30
GROQ_TPM_LIMIT=6000

# ─── TLS / HTTPS (Caddy) ─────────────────────────────────────────────────────
# Your public domain name. Caddy will automatically provision and renew
# Let's Encrypt TLS certificates when this is set to a real domain.
# Development: leave as "localhost" (self-signed, no ACME needed).
# Production:  set to your actual domain, e.g. forensic.yourdomain.com
DOMAIN=localhost

# Email for Let's Encrypt expiration notifications (required for ACME).
# Caddy provisions TLS automatically when DOMAIN is a real domain.
# Dev (DOMAIN=localhost) uses a self-signed cert — ACME_EMAIL is ignored.
ACME_EMAIL=admin@yourdomain.com

# ─── Operational Limits ──────────────────────────────────────────────────────
# Daily LLM/API cost budget in USD for regular users (hard stop when exceeded)
DAILY_COST_QUOTA_USD=50.0

# Daily LLM/API cost budget in USD for admin users (higher ceiling)
DAILY_COST_QUOTA_ADMIN_USD=500.0

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Per-IP rate limit: max API calls per minute for authenticated users
RATE_LIMIT_AUTHENTICATED=60

# Per-IP rate limit: max API calls per minute for unauthenticated users
RATE_LIMIT_ANONYMOUS=10

# Max new investigation requests per user per 5-minute window
# NOTE: window is baked into the var name (5min) — consider using
# RATE_LIMIT_INVESTIGATION_WINDOW_SECONDS=300 for flexibility.
RATE_LIMIT_INVESTIGATION_PER_5MIN=5

# ─── Performance & Caching ───────────────────────────────────────────────────
# Disable Numba JIT compilation inside containers (avoids LLVM overhead on
# CPU-only images; set to 0 only if you have a GPU and need JIT acceleration).
NUMBA_DISABLE_JIT=1

# ─── Observability ───────────────────────────────────────────────────────────
# OpenTelemetry configuration for Jaeger tracing
OTEL_ENABLED=true
OTEL_SERVICE_NAME=forensic-council-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Bearer token required by Prometheus to scrape /api/v1/metrics/raw.
# Must match the value in infra/prometheus.yml (bearer_token_file secret).
# Generate with: openssl rand -hex 32
# This token is NEVER returned to the frontend; it is used only by Prometheus.
METRICS_SCRAPE_TOKEN=__REPLACE_ME_METRICS_TOKEN_MIN_32_CHARS__