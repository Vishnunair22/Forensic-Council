# ============================================================================
# Forensic Council — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# ⚠️  SECURITY: Never commit .env to source control.
# ⚠️  PRODUCTION: Change ALL default values before deploying.
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Security — REQUIRED
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------------
SIGNING_KEY=dev-placeholder-change-me-in-production-generate-with-secrets-token-hex-32

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=forensic_pass
POSTGRES_DB=forensic_council

# ----------------------------------------------------------------------------
# Frontend
# ----------------------------------------------------------------------------
# Password for the auto-login demo investigator account
NEXT_PUBLIC_DEMO_PASSWORD=inv123!

# Backend API URL used by the frontend (must be reachable from the browser)
# In Docker: use http://localhost:8000 (traffic goes out to host and back in)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# LLM Provider
# Recommended: Groq (free tier, ~700 tok/s, best for this project)
#   1. Get a free API key at https://console.groq.com/keys
#   2. Set LLM_PROVIDER=groq and paste your key below
#
# Alternative providers:
#   OpenAI:    LLM_PROVIDER=openai    LLM_MODEL=gpt-4o
#   Anthropic: LLM_PROVIDER=anthropic LLM_MODEL=claude-3-5-sonnet-20241022
#   Disabled:  LLM_PROVIDER=none      (task-decomposition only)
# ----------------------------------------------------------------------------
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.1

# ----------------------------------------------------------------------------
# HuggingFace (optional — required for Agent 2 speaker diarization)
# Get a free token at https://hf.co/settings/tokens
# ----------------------------------------------------------------------------
HF_TOKEN=

# ----------------------------------------------------------------------------
# JWT
# ----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ----------------------------------------------------------------------------
# Production only — Docker registry and image tag for docker-compose.prod.yml
# ----------------------------------------------------------------------------
# DOCKER_REGISTRY=ghcr.io/yourorg
# IMAGE_TAG=latest
# DOMAIN=forensic.yourdomain.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-in-production
