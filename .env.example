# ============================================================================
# Forensic Council — Environment Variables
# ============================================================================
# SETUP:
#   cp .env.example .env
#   Edit .env with your values
#   docker compose -f infra/docker-compose.yml --env-file .env up --build
#
# ⚠️  Never commit .env to source control.
# ⚠️  Change ALL defaults before production deployment.
# ============================================================================

# ─── Docker Project Name ─────────────────────────────────────────────────────
# CRITICAL: This pins the Docker project name so ALL compose variants
# (dev, prod, override) share the same named volumes. Without this, Docker
# uses the working directory as the project name, which can cause dev and prod
# builds to create separate volume pools — resulting in duplicate ML model
# downloads that take 15–60 minutes each.
COMPOSE_PROJECT_NAME=forensic-council

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED for production — the app will refuse to start without this in production mode.
SIGNING_KEY=generate-a-strong-signing-key-for-production-min-32-chars

# Database (PostgreSQL)
# ⚠️  Change these defaults before production deployment!
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=__INVALID_PRODUCTION_PASSWORD__
POSTGRES_DB=forensic_council

# Redis (Mandatory)
# ── Used for Persistent Task Queue, Session State, and WebSocket Pub/Sub.
# ⚠️  CRITICAL: The API and Worker must use the same Redis instance.
# Default in Docker Compose is 'redis:6379'.
REDIS_HOST=redis
REDIS_PORT=6379
# SECURITY: Change this in production! All forensic state traverses Redis.
REDIS_PASSWORD=__INVALID_REDIS_PASSWORD__

# Frontend / Auth
# Demo-only password for local development — NEVER use in production
# Use DEMO_PASSWORD (server-side only) instead of NEXT_PUBLIC_DEMO_PASSWORD
# to avoid baking the secret into the client JS bundle at build time.
DEMO_PASSWORD=__INVALID_DEMO_PASSWORD__
# NEXT_PUBLIC_DEMO_PASSWORD is intentionally excluded — it bakes secrets into the client JS bundle.
# Use DEMO_PASSWORD (server-side only) for authentication.

# Backend API URL used by the BROWSER (must be reachable from the end-user's browser)
# When running Docker on your local machine: http://localhost:8000
# When running on a remote server: http://<server-ip-or-domain>:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Internal API URL used for server-side communication within Docker network
INTERNAL_API_URL=http://backend:8000

# Daily API cost quota per user (investigations cost ~$1.60 each)
# Increase this for development to avoid hitting the limit during testing.
# Set to a high value (e.g. 500) for local dev; lower for production.
DAILY_COST_QUOTA_USD=50.0
DAILY_COST_QUOTA_ADMIN_USD=500.0

# LLM Provider (groq is free and fast — recommended)
# Get a free key at: https://console.groq.com/keys
# ⚠️  REQUIRED for operation — the system will not function without an LLM provider.
LLM_PROVIDER=groq
LLM_API_KEY=__INVALID_GROQ_API_KEY__
LLM_MODEL=llama-3.3-70b-versatile
# Enable ReAct-style reasoning for agents (recommended for complex forensic tasks)
LLM_ENABLE_REACT_REASONING=true
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.1

# Google Gemini Vision API (recommended — required for Agents 1, 4, 5 deep analysis)
# Get a free key at: https://aistudio.google.com/apikey
# ⚠️  REQUIRED for full forensic capability — image/video analysis depends on Gemini.
# Preferred model: gemini-1.5-pro (Forensic OS Standard)
GEMINI_API_KEY=__INVALID_GEMINI_API_KEY__
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FALLBACK_MODELS=gemini-1.5-flash
GEMINI_TIMEOUT=55.0
GEMINI_API_KEY_POLICY_OK=true

# HuggingFace (optional — required for Agent 2 speaker diarization)
# Get a free token at: https://hf.co/settings/tokens
HF_TOKEN=

# JWT
# 60 minutes is appropriate for evidentiary systems.
# Use the refresh endpoint (/api/v1/auth/refresh) to extend sessions.
# ⚠️  Do NOT set this to days-long values in production — a stolen token
#     would be valid for the entire window.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# JWT Secret Key — MUST be set in production (separate from SIGNING_KEY)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED for production — the app will refuse to start without this in production mode.
# Must be at least 32 characters with mixed case, digits, and special chars.
JWT_SECRET_KEY=__INVALID_JWT_SECRET_KEY__

# ─── TLS / HTTPS ─────────────────────────────────────────────────────────────
# Caddy handles TLS automatically via Let's Encrypt — but ONLY when DOMAIN is
# set to a public DNS name that points to this server.
#
#   WITHOUT DOMAIN   → Caddy listens on port 80/443 with a self-signed cert
#                       (suitable for local development behind a VPN only)
#   WITH DOMAIN      → Caddy provisions a free Let's Encrypt cert automatically
#                       and redirects all HTTP → HTTPS
#
# Steps for production HTTPS:
#   1. Point your domain's A record to this server's public IP
#   2. Set DOMAIN=forensic.yourdomain.com below
#   3. Ensure port 80 & 443 are open in your firewall
#   4. Caddy will obtain and auto-renew the cert on first request
#
# ⚠️  Never run with plain HTTP in production — all JWT tokens and evidence
#     file uploads traverse the wire in cleartext without TLS.
#
# DOMAIN=forensic.yourdomain.com

# ─── Bootstrap users (first-run setup) ───────────────────────────────────────
# CRITICAL: Set strong passwords BEFORE first production deploy.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# These passwords are used for the initial admin and investigator accounts.
BOOTSTRAP_ADMIN_PASSWORD=__INVALID_ADMIN_PASSWORD__
BOOTSTRAP_INVESTIGATOR_PASSWORD=__INVALID_INVESTIGATOR_PASSWORD__

# ── ML Model Cache Paths (auto-set in Docker, override for local dev) ───────
# These control where ML models are cached on disk. Defaults are set in Dockerfile.
# Override only if you need custom cache locations for local development.
# TORCH_HOME=/path/to/torch/cache
# HF_HOME=/path/to/huggingface/cache
# YOLO_CONFIG_DIR=/path/to/yolo/cache
# TRANSFORMERS_CACHE=/path/to/transformers/cache

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Authenticated users: 60 requests/minute (can be adjusted per user)
# Anonymous users: 10 requests/minute
# Investigation uploads: 5 per 5 minutes per user (checked separately)
RATE_LIMIT_AUTHENTICATED=60
RATE_LIMIT_ANONYMOUS=10
RATE_LIMIT_INVESTIGATION_PER_5MIN=5
