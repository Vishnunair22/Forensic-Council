# ============================================================================
# Forensic Council — Environment Variables
# ============================================================================
# SETUP:
#   cp .env.example .env
#   Edit .env with your values
#   docker compose -f docs/docker/docker-compose.yml --env-file .env up --build
#
# ⚠️  Never commit .env to source control.
# ⚠️  Change ALL defaults before production deployment.
# ============================================================================

# ─── Docker Project Name ─────────────────────────────────────────────────────
# CRITICAL: This pins the Docker project name so ALL compose variants
# (dev, prod, override) share the same named volumes. Without this, Docker
# uses the working directory as the project name, which can cause dev and prod
# builds to create separate volume pools — resulting in duplicate ML model
# downloads that take 15–60 minutes each.
COMPOSE_PROJECT_NAME=forensic-council

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SIGNING_KEY=dev-placeholder-change-me-in-production-generate-with-secrets-token-hex-32

# Database (PostgreSQL)
POSTGRES_USER=forensic_user
POSTGRES_PASSWORD=forensic_pass
POSTGRES_DB=forensic_council

# Redis
# ⚠️  Change this in production!  Used by the backend for token blacklisting and rate limiting.
REDIS_PASSWORD=forensic_redis_dev_password

# Frontend / Auth
# Password for the auto-login demo investigator account
NEXT_PUBLIC_DEMO_PASSWORD=inv123!

# Backend API URL used by the BROWSER (must be reachable from the end-user's browser)
# When running Docker on your local machine: http://localhost:8000
# When running on a remote server: http://<server-ip-or-domain>:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# LLM Provider (groq is free and fast — recommended)
# Get a free key at: https://console.groq.com/keys
LLM_PROVIDER=groq
LLM_API_KEY=gsk_your_groq_key_here
LLM_MODEL=llama-3.3-70b-versatile
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.1

# Google Gemini Vision API (recommended — required for Agents 1, 3, 5 deep analysis)
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza_your_gemini_key_here
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_FALLBACK_MODELS=gemini-2.5-pro,gemini-2.5-flash
GEMINI_TIMEOUT=55.0

# HuggingFace (optional — required for Agent 2 speaker diarization)
# Get a free token at: https://hf.co/settings/tokens
HF_TOKEN=

# JWT
# 60 minutes is appropriate for evidentiary systems.
# Use the refresh endpoint (/api/v1/auth/refresh) to extend sessions.
# ⚠️  Do NOT set this to days-long values in production — a stolen token
#     would be valid for the entire window.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── TLS / HTTPS ─────────────────────────────────────────────────────────────
# Caddy handles TLS automatically via Let's Encrypt — but ONLY when DOMAIN is
# set to a public DNS name that points to this server.
#
#   WITHOUT DOMAIN   → Caddy listens on port 80/443 with a self-signed cert
#                       (suitable for local development behind a VPN only)
#   WITH DOMAIN      → Caddy provisions a free Let's Encrypt cert automatically
#                       and redirects all HTTP → HTTPS
#
# Steps for production HTTPS:
#   1. Point your domain's A record to this server's public IP
#   2. Set DOMAIN=forensic.yourdomain.com below
#   3. Ensure port 80 & 443 are open in your firewall
#   4. Caddy will obtain and auto-renew the cert on first request
#
# ⚠️  Never run with plain HTTP in production — all JWT tokens and evidence
#     file uploads traverse the wire in cleartext without TLS.
#
# DOMAIN=forensic.yourdomain.com

# ─── Bootstrap users (first-run setup) ───────────────────────────────────────
# Uncomment and set strong passwords before first production deploy.
# BOOTSTRAP_ADMIN_PASSWORD=change-me-in-production
BOOTSTRAP_ADMIN_PASSWORD=admin123!
# BOOTSTRAP_INVESTIGATOR_PASSWORD=change-me-in-production
BOOTSTRAP_INVESTIGATOR_PASSWORD=inv123!
