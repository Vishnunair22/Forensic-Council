# Forensic Council - Caddy Reverse Proxy
#
# Development:
#   DOMAIN=localhost
#
# Production:
#   DOMAIN=forensic.yourdomain.com
#
# Caddy obtains and renews Let's Encrypt certificates automatically when DOMAIN
# is a real public hostname. The DOMAIN value is provided by docker-compose.yml.

{
    admin off

    log {
        output file /var/log/caddy/access.log {
            roll_size 10MB
            roll_keep 10
            roll_keep_for 720h
        }
        format json
    }
}

:80 {
    encode zstd gzip

    @production_domain not host localhost 127.0.0.1
    redir @production_domain https://{host}{uri}

    request_body {
        max_size 55MB
    }

    handle /api/v1/* {
        reverse_proxy backend:8000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Upgrade           {http_upgrade}
            header_up Connection        "{http_connection}"
            flush_interval -1

            transport http {
                response_header_timeout 620s
                dial_timeout            10s
            }
        }
    }

    handle {
        reverse_proxy frontend:3000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Upgrade           {http_upgrade}
            header_up Connection        "{http_connection}"

            transport http {
                response_header_timeout 300s
                dial_timeout            10s
            }
        }
    }
}

{$DOMAIN:localhost} {
    encode zstd gzip

    header {
        Strict-Transport-Security  "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options     "nosniff"
        X-Robots-Tag               "none"
        X-XSS-Protection           "0"
        X-Frame-Options            "DENY"
        Referrer-Policy            "strict-origin-when-cross-origin"
        Permissions-Policy         "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        Content-Security-Policy    "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' fonts.gstatic.com data:; connect-src 'self' wss://{$DOMAIN} ws://localhost:*; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"
        -Server
        -X-Powered-By
    }

    request_body {
        max_size 55MB
    }

    # Backend API and WebSocket/SSE streams. Next.js API routes under /api/auth/*
    # must remain routed to the frontend, so keep this matcher scoped to /api/v1/*.
    handle /api/v1/* {
        reverse_proxy backend:8000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Upgrade           {http_upgrade}
            header_up Connection        "{http_connection}"

            health_uri      /health
            health_interval 10s
            health_timeout  5s

            flush_interval -1

            transport http {
                response_header_timeout 620s
                dial_timeout            10s
                read_buffer             64KB
                write_buffer            64KB
            }
        }
    }

    handle {
        reverse_proxy frontend:3000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Upgrade           {http_upgrade}
            header_up Connection        "{http_connection}"

            transport http {
                response_header_timeout 300s
                dial_timeout            10s
            }
        }
    }
}
