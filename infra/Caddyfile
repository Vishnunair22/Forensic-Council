# ============================================================================
# Forensic Council - Caddy Reverse Proxy Configuration
# ============================================================================
# Usage:
#   Development (localhost self-signed): DOMAIN not set or DOMAIN=localhost
#   Production (Let's Encrypt):          DOMAIN=forensic.yourdomain.com
#
# Caddy automatically obtains and renews TLS certificates from Let's Encrypt
# when a real domain is configured.  No manual cert management required.
#
# The {$DOMAIN} placeholder is replaced at runtime by the DOMAIN env var
# (set in docker-compose.yml → environment → DOMAIN).
# ============================================================================

{
    # Disable admin API in production to reduce attack surface
    admin off

    # Structured JSON access log
    log {
        output file /var/log/caddy/access.log {
            roll_size 10MB
            roll_keep 10
            roll_keep_for 720h
        }
        format json
    }
}

# HTTP → HTTPS redirect for non-localhost domains
:80 {
    # For localhost development, serve HTTP directly without redirect.
    # Only redirect to HTTPS when DOMAIN is a real production domain.
    @production_domain not host localhost 127.0.0.1
    redir @production_domain https://{host}{uri}

    # Localhost HTTP: same path-based routing as the HTTPS block below.
    # /api/v1/* → FastAPI backend; everything else → Next.js frontend.
    handle /api/v1/* {
        reverse_proxy backend:8000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Upgrade           {http_upgrade}
            header_up Connection        "{http_connection}"
            # flush_interval -1: disable buffering for WebSocket and SSE streams
            flush_interval -1
            transport http {
                response_header_timeout 620s
                dial_timeout            10s
            }
        }
    }

    request_body {
        max_size 55MB
    }

    handle {
        reverse_proxy frontend:3000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
            transport http {
                response_header_timeout 300s
                dial_timeout            10s
            }
        }
    }
}

# Main site block
# {$DOMAIN} is set from the DOMAIN env var (see docker-compose.yml).
# When DOMAIN=localhost → self-signed cert.
# When DOMAIN=forensic.yourdomain.com → auto Let's Encrypt.
{$DOMAIN:localhost} {

    # Compress all responses (Caddy handles this; Next.js compress is disabled)
    encode zstd gzip

    # Security headers applied to every response
    header {
        Strict-Transport-Security  "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options     "nosniff"
        X-Robots-Tag               "none"
        X-XSS-Protection           "0"
        X-Frame-Options            "DENY"
        Referrer-Policy            "strict-origin-when-cross-origin"
        Permissions-Policy         "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        Content-Security-Policy    "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' fonts.gstatic.com data:; connect-src 'self' wss: ws: https://generativelanguage.googleapis.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"
        -Server
        -X-Powered-By
    }

    # Global upload limit enforcement at the proxy level
    request_body {
        max_size 55MB
    }

    # Backend API + WebSocket (only /api/v1/* goes to FastAPI backend).
    # Next.js API routes live under /api/auth/* and must reach the frontend
    # container — do NOT widen this rule to /api/* or those routes break.
    handle /api/v1/* {
        reverse_proxy backend:8000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Upgrade           {http_upgrade}
            header_up Connection        "{http_connection}"

            health_uri      /health
            health_interval 10s
            health_timeout  5s

            # flush_interval -1: disable buffering for WebSocket and SSE streams
            flush_interval -1

            transport http {
                response_header_timeout 620s
                dial_timeout            10s
                read_buffer             64KB
                write_buffer            64KB
            }
        }
    }

    # Frontend (Next.js) — catch-all
    handle {
        reverse_proxy frontend:3000 {
            header_up Host              {host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}

            transport http {
                # 300 s covers Next.js dev-mode on-demand compilation.  First-load
                # compilation measured at 70–130 s on typical hardware; 300 s gives
                # generous headroom.  Production builds respond in < 1 s so this is
                # effectively a no-op in prod.
                response_header_timeout 300s
                dial_timeout            10s
            }
        }
    }
}