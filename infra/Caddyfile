# Forensic Council - Caddy Reverse Proxy
#
# Development:
#   DOMAIN=localhost
#
# Production:
#   DOMAIN=forensic.yourdomain.com
#   ACME_EMAIL=admin@yourdomain.com

{
    admin off
    auto_https off
    http_port 80
    https_port 443
}

:80 {
    encode zstd gzip

    @production_domain not host localhost 127.0.0.1
    redir @production_domain https://{host}{uri}

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-Robots-Tag "none"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        -X-Powered-By
    }

    request_body {
        max_size 55MB
    }

    handle /api/v1/* {
        reverse_proxy backend:8000 {
            header_up Host {host}
            header_up Upgrade {header.Upgrade}
            header_up Connection {header.Connection}
            flush_interval -1

            transport http {
                response_header_timeout 620s
                dial_timeout 10s
                read_buffer 64KB
                write_buffer 64KB
            }
        }
    }

    handle {
        reverse_proxy frontend:3000 {
            header_up Host {host}

            transport http {
                response_header_timeout 300s
                dial_timeout 10s
            }
        }
    }
}

{$DOMAIN:localhost} {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Robots-Tag "none"
        X-XSS-Protection "0"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        -X-Powered-By
    }

    request_body {
        max_size 55MB
    }

    handle /api/v1/* {
        reverse_proxy backend:8000 {
            header_up Host {host}
            header_up Upgrade {header.Upgrade}
            header_up Connection {header.Connection}
            flush_interval -1

            transport http {
                response_header_timeout 620s
                dial_timeout 10s
                read_buffer 64KB
                write_buffer 64KB
            }
        }
    }

    handle {
        reverse_proxy frontend:3000 {
            header_up Host {host}

            transport http {
                response_header_timeout 300s
                dial_timeout 10s
            }
        }
    }
}