# Forensic Council - Caddy Reverse Proxy
#
# Development:
#   DOMAIN=localhost
#
# Production:
#   DOMAIN=forensic.yourdomain.com
#   ACME_EMAIL=admin@yourdomain.com

{
    admin off
    # auto_https is ON by default.
    # For production domains Caddy auto-provisions Let's Encrypt certs.
    # For localhost Caddy uses a self-signed internal cert (no ACME needed).
    # Set ACME_EMAIL in .env to receive cert expiry notifications.
    email {$ACME_EMAIL:admin@localhost}
    http_port 80
    https_port 443
}

:80, :443 {
    encode zstd gzip

    # Redirect HTTP to HTTPS for non-localhost domains.
    # Caddy handles automatic HTTPS for specific domains, but for a generic
    # config, we ensure redirection if accessed via port 80.
    @http {
        protocol http
        not host localhost 127.0.0.1
    }
    redir @http https://{host}{uri}

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-Robots-Tag "none"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        -X-Powered-By
    }

    request_body {
        max_size 55MB
    }

    handle /api/v1/* {
        reverse_proxy backend:8000 {
            header_up Host {host}
            flush_interval -1

            transport http {
                response_header_timeout 620s
                dial_timeout 10s
                read_buffer 64KB
                write_buffer 64KB
            }
        }
    }

    handle {
        reverse_proxy frontend:3000 {
            header_up Host {host}

            transport http {
                response_header_timeout 300s
                dial_timeout 10s
            }
        }
    }
}