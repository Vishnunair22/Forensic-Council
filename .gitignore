# ============================================================================
# Forensic Council — .gitignore
# ============================================================================

# Environment files — NEVER commit secrets
.env
backend/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.whl
*.pth

# Virtual environments
.venv/
venv/
env/

# uv
.python-version

# Node.js / Next.js
node_modules/
.next/
out/
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/lint.json
frontend/lint_output.txt

# TypeScript
*.tsbuildinfo

# Test output
coverage/
test-results/

# Docker
docker-compose.override.yml.bak

# Storage & model caches (large binary files)
backend/storage/evidence/
backend/storage/keys/
backend/cache/

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Temporary files
*.tmp
*.bak
$null
