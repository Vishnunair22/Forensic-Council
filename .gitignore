# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.key
*.pem
*.p12
*.pfx

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.so
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Node / Next.js ───────────────────────────────────────────────────────────
node_modules/
frontend/.next/
frontend/out/
frontend/.npm
frontend/.cache
*.tsbuildinfo

# ── Docker build artefacts ───────────────────────────────────────────────────
# (volumes, build context detritus)
/backend/storage/evidence/*
!/backend/storage/evidence/.gitkeep
/backend/storage/keys/*
!/backend/storage/keys/.gitkeep

# ── ML model caches (large binary files) ─────────────────────────────────────
/backend/cache/
*.pt
*.pth
*.onnx
*.bin
*.safetensors

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
