# ── Secrets & Environment ────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.*.local
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
*Keys*.txt
*keys*.txt
*secrets*
*credentials*
*token*.txt
*api_key*

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.so
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Node / Next.js ───────────────────────────────────────────────────────────
node_modules/
frontend/.next/
frontend/out/
frontend/.npm
frontend/.cache
*.tsbuildinfo

# ── Docker build artefacts ───────────────────────────────────────────────────
# (volumes, build context detritus)
/backend/storage/evidence/*
!/backend/storage/evidence/.gitkeep
/backend/storage/keys/*
!/backend/storage/keys/.gitkeep
/backend/storage/calibration_models/

# ── ML model caches (large binary files) ─────────────────────────────────────
/backend/cache/
*.pt
*.pth
*.onnx
*.bin
*.safetensors

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
nul

# ── Test fixtures (binary, not for version control) ──────────────────────────
tests/fixtures/*.webp
tests/fixtures/*.png
tests/fixtures/*.jpg
tests/fixtures/*.jpeg
!tests/fixtures/.gitkeep

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
