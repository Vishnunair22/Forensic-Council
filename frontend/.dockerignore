# ============================================================================
# Frontend .dockerignore
# ============================================================================
# Prevents unnecessary files from being sent as Docker build context.

# Node modules (Docker installs its own via npm ci)
node_modules/

# Next.js build output
.next/
out/

# Environment files
.env
.env.*
!.env.example

# Development artifacts
*.log
lint.json
lint_output.txt

# Version control
.git/
.gitignore

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Test artifacts
coverage/

# TypeScript build info
*.tsbuildinfo
