# ============================================================================
# Frontend .dockerignore
# ============================================================================

# Node modules (Docker installs its own)
node_modules/
npm-debug.log*

# Next.js build outputs
.next/
out/

# Env files
.env
.env.*
!.env.example

# Dev artifacts
*.log
coverage/
*.tsbuildinfo

# Version control
.git/
.gitignore
.github/
*.md
README*

# Test files
tests/

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
