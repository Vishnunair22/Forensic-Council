# ============================================================================
# Frontend .dockerignore
# ============================================================================

# Node modules (Docker installs its own)
node_modules/
npm-debug.log*

# Next.js build outputs
.next/
out/

# Env files and secrets
.env
.env.*
!.env.example
.env.production
.env.staging

# Cache that may contain sensitive build data
.next/cache
.npm
.cache

# Dev artifacts
*.log
coverage/
*.tsbuildinfo

# Version control
.git/
.gitignore
.github/
*.md
README*

# Test files
tests/

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
